{
  "name": "pyielink-engine",
  "version": "1.0.0",
  "description": "PyieLink — Modular Networking & Security Framework",
  "main": "electron/main.js",
  "scripts": {
    "dev:backend": "node backend/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && electron-builder",
    "start": "npm run dev"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pino": "^8.15.0",
    "pino-pretty": "^10.2.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.2",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.pyielink.engine",
    "productName": "PyieLink Engine",
    "directories": { "output": "dist" },
    "files": ["electron/**", "backend/**", "scripts/**", "config/**", "frontend/dist/**"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
